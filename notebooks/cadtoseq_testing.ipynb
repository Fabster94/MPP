```python
"""
Automated analysis of hyperparameter tuning results.
This cell analyzes patterns in the top performing models and generates insights.
"""

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np
from pathlib import Path

def analyze_tuning_patterns(tuning_df, top_n=10):
    """
    Analyze patterns in hyperparameter tuning results
    
    Parameters:
    -----------
    tuning_df : pd.DataFrame
        DataFrame with tuning results (must have hp_* columns and val_loss)
    top_n : int
        Number of top models to analyze
    """
    
    # Get top N models
    top_models = tuning_df.nsmallest(top_n, 'val_loss')
    
    # Print header
    print("=" * 80)
    print(f"HYPERPARAMETER TUNING ANALYSIS - TOP {top_n} MODELS")
    print("=" * 80)
    
    # 1. Performance Overview
    print("\n📊 PERFORMANCE OVERVIEW:")
    print(f"Best Val Loss: {top_models.iloc[0]['val_loss']:.4f}")
    print(f"Top {top_n} Average: {top_models['val_loss'].mean():.4f}")
    print(f"Range: {top_models['val_loss'].min():.4f} - {top_models['val_loss'].max():.4f}")
    
    # 2. Analyze each hyperparameter
    print("\n🔍 HYPERPARAMETER PATTERNS IN TOP MODELS:")
    print("-" * 60)
    
    hp_columns = [col for col in tuning_df.columns if col.startswith('hp_')]
    
    for hp in hp_columns:
        param_name = hp[3:]  # Remove 'hp_' prefix
        print(f"\n{param_name.upper()}:")
        
        # For categorical parameters
        if tuning_df[hp].dtype in ['int64', 'object'] or len(tuning_df[hp].unique()) < 10:
            value_counts = top_models[hp].value_counts()
            for value, count in value_counts.items():
                percentage = (count / top_n) * 100
                print(f"  {value}: {count}/{top_n} ({percentage:.0f}%)")
                
        # For continuous parameters
        else:
            print(f"  Mean: {top_models[hp].mean():.6f}")
            print(f"  Std: {top_models[hp].std():.6f}")
            print(f"  Range: {top_models[hp].min():.6f} - {top_models[hp].max():.6f}")
    
    # 3. Key Insights
    print("\n💡 KEY INSIGHTS:")
    print("-" * 60)
    
    # Find dominant values
    insights = []
    
    for hp in hp_columns:
        param_name = hp[3:]
        if tuning_df[hp].dtype in ['int64', 'object'] or len(tuning_df[hp].unique()) < 10:
            mode_value = top_models[hp].mode()[0]
            mode_count = (top_models[hp] == mode_value).sum()
            if mode_count >= top_n * 0.7:  # 70% threshold
                insights.append(f"• {param_name} = {mode_value} dominates ({mode_count}/{top_n} models)")
    
    # Learning rate insight
    if 'hp_lr' in top_models.columns:
        lr_mean = top_models['hp_lr'].mean()
        lr_range = (top_models['hp_lr'].min(), top_models['hp_lr'].max())
        insights.append(f"• Learning rate sweet spot: {lr_mean:.2e} (range: {lr_range[0]:.2e} - {lr_range[1]:.2e})")
    
    for insight in insights:
        print(insight)
    
    return top_models

def create_hyperparameter_visualizations(tuning_df, top_n=10, figsize=(20, 12)):
    """
    Create comprehensive visualizations of hyperparameter patterns
    """
    top_models = tuning_df.nsmallest(top_n, 'val_loss')
    all_models = tuning_df
    
    # Create figure with subplots
    fig = plt.figure(figsize=figsize)
    
    # Define subplot layout
    gs = fig.add_gridspec(3, 4, hspace=0.3, wspace=0.3)
    
    # 1. Val Loss Distribution
    ax1 = fig.add_subplot(gs[0, 0:2])
    ax1.hist(all_models['val_loss'], bins=30, alpha=0.7, color='lightblue', edgecolor='black')
    ax1.axvline(top_models['val_loss'].max(), color='green', linestyle='--', label=f'Top {top_n} threshold')
    ax1.axvline(top_models['val_loss'].min(), color='red', linestyle='--', label='Best model')
    ax1.set_xlabel('Validation Loss')
    ax1.set_ylabel('Count')
    ax1.set_title('Validation Loss Distribution')
    ax1.legend()
    
    # 2. Learning Rate vs Val Loss
    ax2 = fig.add_subplot(gs[0, 2:4])
    scatter = ax2.scatter(all_models['hp_lr'], all_models['val_loss'], 
                         c=all_models['val_loss'], cmap='viridis', alpha=0.6)
    ax2.scatter(top_models['hp_lr'], top_models['val_loss'], 
               color='red', s=100, marker='*', label=f'Top {top_n}')
    ax2.set_xscale('log')
    ax2.set_xlabel('Learning Rate')
    ax2.set_ylabel('Validation Loss')
    ax2.set_title('Learning Rate Impact')
    ax2.legend()
    
    # 3. Embed Dim Distribution
    ax3 = fig.add_subplot(gs[1, 0])
    embed_counts = top_models['hp_embed_dim'].value_counts()
    ax3.bar(embed_counts.index.astype(str), embed_counts.values, color='coral')
    ax3.set_xlabel('Embed Dimension')
    ax3.set_ylabel(f'Count in Top {top_n}')
    ax3.set_title('Embed Dim in Top Models')
    
    # 4. Num Layers Distribution
    ax4 = fig.add_subplot(gs[1, 1])
    layers_counts = top_models['hp_num_layers'].value_counts()
    ax4.bar(layers_counts.index.astype(str), layers_counts.values, color='lightgreen')
    ax4.set_xlabel('Number of Layers')
    ax4.set_ylabel(f'Count in Top {top_n}')
    ax4.set_title('Layers in Top Models')
    
    # 5. Num Heads Distribution
    ax5 = fig.add_subplot(gs[1, 2])
    heads_counts = top_models['hp_num_heads'].value_counts()
    ax5.bar(heads_counts.index.astype(str), heads_counts.values, color='skyblue')
    ax5.set_xlabel('Number of Heads')
    ax5.set_ylabel(f'Count in Top {top_n}')
    ax5.set_title('Heads in Top Models')
    
    # 6. Dropout Distribution
    ax6 = fig.add_subplot(gs[1, 3])
    ax6.hist(top_models['hp_dropout'], bins=10, color='plum', edgecolor='black')
    ax6.set_xlabel('Dropout Rate')
    ax6.set_ylabel(f'Count in Top {top_n}')
    ax6.set_title('Dropout in Top Models')
    
    # 7. Correlation Heatmap
    ax7 = fig.add_subplot(gs[2, :2])
    hp_cols = ['hp_lr', 'hp_embed_dim', 'hp_num_layers', 'hp_num_heads', 'hp_dropout', 'val_loss']
    corr_data = top_models[hp_cols].corr()
    sns.heatmap(corr_data, annot=True, fmt='.2f', cmap='coolwarm', center=0, ax=ax7)
    ax7.set_title(f'Correlation Matrix (Top {top_n} Models)')
    
    # 8. Performance by Architecture
    ax8 = fig.add_subplot(gs[2, 2:])
    # Create architecture signature
    all_models['architecture'] = (all_models['hp_embed_dim'].astype(str) + '-' + 
                                 all_models['hp_num_layers'].astype(str) + '-' + 
                                 all_models['hp_num_heads'].astype(str))
    
    # Get top 5 architectures by count
    top_archs = all_models['architecture'].value_counts().head(5).index
    arch_data = all_models[all_models['architecture'].isin(top_archs)]
    
    # Box plot
    arch_data.boxplot(column='val_loss', by='architecture', ax=ax8)
    ax8.set_xlabel('Architecture (embed-layers-heads)')
    ax8.set_ylabel('Validation Loss')
    ax8.set_title('Performance by Architecture')
    plt.setp(ax8.xaxis.get_majorticklabels(), rotation=45)
    
    plt.suptitle(f'Hyperparameter Tuning Analysis - {len(all_models)} Trials', fontsize=16)
    plt.tight_layout()
    plt.show()

def generate_config_recommendation(top_models):
    """
    Generate configuration recommendation based on analysis
    """
    print("\n🚀 RECOMMENDED CONFIGURATION FOR FINAL TRAINING:")
    print("=" * 80)
    print("model = ProcessClassificationTrsfmEncoderModule(")
    
    # For each hyperparameter, recommend based on top models
    recommendations = {}
    
    # Categorical parameters - use mode
    for param in ['embed_dim', 'num_layers', 'num_heads']:
        col = f'hp_{param}'
        if col in top_models.columns:
            mode_value = top_models[col].mode()[0]
            recommendations[param] = mode_value
            print(f"    {param}={mode_value},")
    
    # Continuous parameters - use mean of top 3
    top3 = top_models.head(3)
    
    if 'hp_lr' in top3.columns:
        lr_mean = top3['hp_lr'].mean()
        print(f"    lr={lr_mean:.6f},")
        
    if 'hp_dropout' in top3.columns:
        dropout_mean = top3['hp_dropout'].mean()
        print(f"    dropout={dropout_mean:.3f},")
        
    if 'hp_weight_decay' in top3.columns:
        wd_mean = top3['hp_weight_decay'].mean()
        print(f"    weight_decay={wd_mean:.2e},")
    
    print("    max_epochs=500  # For final training")
    print(")")
    
    print("\n# Expected performance: Val Loss ~{:.4f}".format(top_models.iloc[0]['val_loss']))

# ========== MAIN ANALYSIS ==========

# Run the analysis
print("Loading tuning results...")
top_models = analyze_tuning_patterns(tuning_df, top_n=10)

# Create visualizations
print("\n📊 Creating visualizations...")
create_hyperparameter_visualizations(tuning_df, top_n=10)

# Generate recommendations
generate_config_recommendation(top_models)

# Additional statistics
print("\n📈 ADDITIONAL STATISTICS:")
print("-" * 60)
print(f"Total trials analyzed: {len(tuning_df)}")
print(f"Success rate (val_loss < 0.40): {(tuning_df['val_loss'] < 0.40).sum() / len(tuning_df) * 100:.1f}%")
print(f"Trials with embed_dim=256: {(tuning_df['hp_embed_dim'] == 256).sum()}")
print(f"Best embed_dim=256 result: {tuning_df[tuning_df['hp_embed_dim'] == 256]['val_loss'].min():.4f}")
print(f"Best embed_dim=128 result: {tuning_df[tuning_df['hp_embed_dim'] == 128]['val_loss'].min():.4f}")
