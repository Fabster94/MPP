"""
Load all hyperparameter tuning results from saved JSON files.
Collects trial configurations, metrics, and hyperparameters into a pandas DataFrame
for easy analysis and sorting by performance.
"""

def load_tuning_results():
    """Load all trial results from tuning directory"""
    results = []
    
    for config_file in TUNING_DIR.rglob("trial_config.json"):
        with open(config_file) as f:
            data = json.load(f)
            # Flatten nested structure for easier analysis
            flat_data = {
                'trial_number': data['trial_number'],
                'trial_id': data['trial_id'],
                'val_loss': data['metrics']['val_loss'],
                'val_acc': data['metrics']['val_acc'],
                'epochs_trained': data.get('epochs_trained', 'N/A'),
                'checkpoint_path': data['best_checkpoint'],
                **{f'hp_{k}': v for k, v in data['hyperparameters'].items()}
            }
            results.append(flat_data)
    
    return pd.DataFrame(results).sort_values('val_loss')

# Load results
tuning_df = load_tuning_results()
print(f"✅ Loaded {len(tuning_df)} trials\n")

# Show top 5
print("🏆 Top 5 Models:")
display(tuning_df[['trial_number', 'val_loss', 'val_acc', 'epochs_trained']].head())

```


